{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@ai-enhanced-web-apps/source"],
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["apps/chat-client-react/src/lib/*"],
      "@apps/chat-client-react/*": ["apps/chat-client-react/src/*"]
    }
  }
}
