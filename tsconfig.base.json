{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@ai-enhanced-web-apps/source"],
    "baseUrl": ".",
    "paths": {
      "@lib/*": ["apps/chat-client-react/src/lib/*"],
      "@apps/chat-client-react/*": ["apps/chat-client-react/src/*"],
      "@ai-enhanced-web-apps/shared-utils": ["libs/shared-utils/src/index.ts"],
      "@ai-enhanced-web-apps/shared-utils/ai-providers": ["libs/shared-utils/src/lib/ai-providers.ts"],
      "@ai-enhanced-web-apps/shared-utils/*": ["libs/shared-utils/src/*"],
      "@ai-enhanced-web-apps/shared-types": ["libs/shared-types/src/index.ts"],
      "@ai-enhanced-web-apps/chat-ui": ["libs/chat-ui/src/index.ts"],
      "@ai-enhanced-web-apps/chat-hooks": ["libs/chat-hooks/src/index.ts"]
    }
  }
}
